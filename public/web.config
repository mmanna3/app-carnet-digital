<?xml version="1.0" encoding="utf-8"?>
<!--
  IIS (Plesk en Windows): rutas con barra final que coinciden con una carpeta
  física pero sin index.html (p. ej. /torneos/zona-detalle/ con export estático
  de Expo) devuelven 403.14. Esta regla reescribe a la página hermana *.html.

  Requiere el módulo "URL Rewrite" en IIS (habitual en Plesk).
-->
<configuration>
  <system.webServer>
    <defaultDocument>
      <files>
        <clear />
        <add value="index.html" />
      </files>
    </defaultDocument>
    <rewrite>
      <rules>
        <rule name="Expo static: carpeta sin index a ruta .html" stopProcessing="true">
          <match url="(.*)/([^/]+)/$" />
          <conditions logicalGrouping="MatchAll">
            <add input="{REQUEST_FILENAME}" matchType="IsDirectory" />
            <add input="{REQUEST_FILENAME}\index.html" matchType="IsFile" negate="true" />
          </conditions>
          <action type="Rewrite" url="/{R:1}/{R:2}.html" appendQueryString="true" />
        </rule>
      </rules>
    </rewrite>
  </system.webServer>
</configuration>
