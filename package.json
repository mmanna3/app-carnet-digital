{
  "name": "carnet-digital",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "limpiar": "rm -rf node_modules && rm package-lock.json && rm -rf .expo && rm -rf .expo-shared && npm i",
    "ios:build": "eas build --platform ios --profile production-${LIGA_ID:?LIGA_ID es obligatorio}",
    "ios:deploy": "eas submit --platform ios --profile production-${LIGA_ID:?LIGA_ID es obligatorio}",
    "android:build": "eas build --platform android --profile production-${LIGA_ID:?LIGA_ID es obligatorio}",
    "android:deploy": "eas submit --platform android --profile production-${LIGA_ID:?LIGA_ID es obligatorio}",
    "start": "node scripts/print-api-url.js && expo start",
    "start:dev": "node scripts/print-api-url.js && expo start --dev-client",
    "start:prod": "expo start --no-dev",
    "android": "expo run:android",
    "android:dev": "expo start --android --dev-client",
    "android:prod": "expo start --android --no-dev",
    "ios": "expo run:ios",
    "ios:dev": "expo start --ios --dev-client",
    "ios:prod": "expo start --ios --no-dev",
    "test": "jest --watchAll",
    "test:ci": "jest --no-coverage",
    "e2e": "bash e2e/run-e2e-android-dev.sh",
    "e2e:ios": "bash e2e/run-e2e-ios-dev.sh",
    "e2e:limpio": "bash e2e/run-e2e-android-limpio.sh",
    "pretest:e2e": "adb push e2e/foto-e2e.jpg /sdcard/DCIM/foto-e2e-1.jpg && adb push e2e/foto-e2e.jpg /sdcard/DCIM/foto-e2e-2.jpg && adb push e2e/foto-e2e.jpg /sdcard/DCIM/foto-e2e-3.jpg && adb shell am broadcast -a android.intent.action.MEDIA_SCANNER_SCAN_FILE -d file:///sdcard/DCIM/foto-e2e-1.jpg && adb shell am broadcast -a android.intent.action.MEDIA_SCANNER_SCAN_FILE -d file:///sdcard/DCIM/foto-e2e-2.jpg && adb shell am broadcast -a android.intent.action.MEDIA_SCANNER_SCAN_FILE -d file:///sdcard/DCIM/foto-e2e-3.jpg",
    "test:e2e": "maestro test --debug-output ./e2e-debug --format HTML --output e2e-report.html e2e",
    "test:e2e:ios": "maestro -p ios test e2e/",
    "test:e2e:android": "maestro -p android test e2e/",
    "test:e2e:single": "maestro test",
    "test:e2e:debug": "maestro test --debug-output ./e2e-debug --format HTML --output e2e-report.html e2e/",
    "test:e2e:record": "maestro record --local",
    "prepush": "npm run format && npm run lint:fix && npm run typecheck",
    "typecheck": "tsc --noEmit",
    "lint": "expo lint",
    "lint:fix": "expo lint --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "generate:api": "nswag run nswag.json",
    "prebuild": "expo prebuild",
    "prebuild:clean": "expo prebuild --clean && node scripts/patch-splash-background.js",
    "postinstall": "patch-package",
    "prepare": "husky"
  },
  "jest": {
    "preset": "jest-expo",
    "setupFilesAfterEnv": [
      "<rootDir>/jest.setup.ts"
    ],
    "moduleNameMapper": {
      "^@/flujos/(.*)$": "<rootDir>/app/flujos/$1",
      "^@/design-system/(.*)$": "<rootDir>/app/design-system/$1",
      "^@/logica-compartida/(.*)$": "<rootDir>/app/logica-compartida/$1",
      "^@/lib/(.*)$": "<rootDir>/app/logica-compartida/$1",
      "^@/constants/(.*)$": "<rootDir>/app/logica-compartida/constantes/$1",
      "^@/(.*)$": "<rootDir>/$1"
    }
  },
  "dependencies": {
    "@expo-google-fonts/inter": "^0.4.2",
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "9.1.0",
    "@tanstack/react-query": "^5.68.0",
    "expo": "~54.0.0",
    "expo-build-properties": "~56.0.16",
    "expo-constants": "^56.0.16",
    "expo-font": "~56.0.5",
    "expo-image-manipulator": "~56.0.16",
    "expo-image-picker": "~56.0.15",
    "expo-linear-gradient": "~56.0.4",
    "expo-linking": "^56.0.13",
    "expo-modules-core": "^56.0.14",
    "expo-print": "~56.0.3",
    "expo-router": "^56.2.8",
    "expo-sharing": "~56.0.15",
    "expo-splash-screen": "^56.0.10",
    "expo-status-bar": "~56.0.4",
    "expo-system-ui": "~56.0.5",
    "expo-web-browser": "~56.0.5",
    "nativewind": "^4.2.2",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-popup-menu": "^0.17.0",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.8.3",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.2.0",
    "eslint": "^9.0.0",
    "eslint-config-expo": "~56.0.4",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "jest": "^29.2.1",
    "jest-expo": "~56.0.4",
    "patch-package": "^8.0.1",
    "prettier": "^3.8.1",
    "react-test-renderer": "19.2.3",
    "tailwindcss": "^3.4.19",
    "typescript": "~6.0.3"
  },
  "private": true
}
